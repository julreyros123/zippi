# Backend .env template — copy to .env and fill in your values

# REQUIRED: JWT secret key — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Server port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Database URL (SQLite for dev, PostgreSQL for production)
DATABASE_URL=file:./prisma/dev.db
# DATABASE_URL=postgresql://user:password@localhost:5432/zippi
